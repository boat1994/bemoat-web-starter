#!/usr/bin/env sh
# Optional local pre-push harness. CI is authoritative.
# Runs a fast subset only — no lint or build (see AGENTS.md § Validation tiers).
set -eu

echo "pre-push: running repository safety guard..."
pnpm run guard:safety

echo "pre-push: running typecheck..."
pnpm run typecheck

echo "pre-push: running integration tests..."
pnpm run test:int

echo "pre-push: checks passed."
