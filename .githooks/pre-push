#!/usr/bin/env sh
# Optional local pre-push harness. CI is authoritative.
# Runs a fast child-safe subset only — bemoat:* scripts that sync adds when missing.
set -eu

echo "pre-push: checking branch safety..."
bash scripts/check-branch-safety.sh

echo "pre-push: running repository safety guard..."
pnpm run bemoat:guard:safety

echo "pre-push: running integration tests..."
pnpm run bemoat:test:int

echo "pre-push: checks passed."
